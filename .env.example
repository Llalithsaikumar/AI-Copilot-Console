OPENROUTER_API_KEY=sk-or-your-key
OPENROUTER_CHAT_MODEL=meta-llama/llama-3.3-70b-instruct:free
OPENROUTER_CHAT_FALLBACK_MODELS=tencent/hy3-preview:free,google/gemma-4-31b-it:free,minimax/minimax-m2.5:free,z-ai/glm-4.5-air:free,openai/gpt-oss-120b:free,meta-llama/llama-3.3-70b-instruct:free,google/gemma-3-27b-it:free
OPENROUTER_EMBEDDING_MODEL=openai/text-embedding-3-small

OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_APP_TITLE=AI Copilot Local Console
OPENROUTER_HTTP_REFERER=http://localhost:5173

GEMINI_API_KEY=your-gemini-api-key
GEMINI_CHAT_MODEL=gemini-2.5-flash-lite
GEMINI_EMBEDDING_MODEL=text-embedding-004
GEMINI_BASE_URL=https://generativelanguage.googleapis.com/v1beta

DATA_DIR=data
CHROMA_COLLECTION=knowledge_base
SQLITE_PATH=data/copilot.sqlite3
PRICE_PER_1K_TOKENS=0.0

ENV=dev
PUBLIC_API_URL=http://localhost:8000
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
STORAGE_BACKEND=sqlite
POSTGRES_DSN=postgresql://postgres:postgres@postgres:5432/copilot
MAX_UPLOAD_MB=15

VITE_CLERK_PUBLISHABLE_KEY=your-clerk-publishable-key
# Backend Clerk JWT verification (see Clerk dashboard → API keys → JWT validation)
CLERK_JWKS_URL=https://your-instance.clerk.accounts.dev/.well-known/jwks.json
CLERK_ISSUER=https://your-instance.clerk.accounts.dev
# Local/testing only — returns DEV_ACCOUNT_ID without verifying JWT when JWKS unset (ENV=dev)
# AUTH_DISABLED=true
# DEV_ACCOUNT_ID=dev-local
